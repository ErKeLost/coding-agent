{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Rovix",
  "identifier": "com.codingagent.desktop",
  "version": "0.2.11",
  "build": {
    "beforeDevCommand": "node ./scripts/desktop-dev-server.mjs",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "bun run build && node scripts/prepare-sidecar.mjs",
    "frontendDist": "../desktop-dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Rovix",
        "width": 1440,
        "height": 960,
        "minWidth": 1080,
        "minHeight": 720,
        "resizable": true,
        "create": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "resources": ["next-server/**/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIxQzFEQjFGNDAwNjM2MUMKUldRY05nWkFIOXZCSVkxV3NnMmRvMk1BRmFJS3d5TkhLQVZHVTBHdGNyVU1weTFZd0tGanlYbzYK",
      "endpoints": [
        "https://github.com/ErKeLost/coding-agent/releases/latest/download/latest.json"
      ]
    }
  }
}
